{
  "env": {
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "allow": [
      "Bash(bash -n:*)",
      "Bash(bash tests/run_tests.sh:*)",
      "Bash(bash tests/lib/bats-core/bin/bats:*)",
      "Bash(./tests/lib/bats-core/bin/bats:*)",
      "Bash(tests/lib/bats-core/bin/bats:*)",
      "Bash(bats:*)",
      "Bash(FUZZ_ITERATIONS=*)",
      "Bash(git submodule:*)",
      "Bash(jq:*)",
      "Bash(wc -l:*)",
      "Bash(xargs grep:*)",
      "Bash(cd:*)",
      "Bash(git rev-parse:*)",
      "Bash(git clone --depth 1 https://github.com/MetaCubeX/Meta-Docs.git:*)",
      "Bash(git -C .claude/cache/mihomo-wiki rev-parse:*)",
      "Bash(git -C .claude/cache/mihomo-wiki fetch:*)",
      "Bash(git -C .claude/cache/mihomo-wiki reset --hard origin/main:*)",
      "Bash(git -C .claude/cache/mihomo-wiki log:*)",
      "Bash(git -C .claude/cache/mihomo-wiki ls-files:*)",
      "Bash(find .claude/cache/mihomo-wiki:*)",
      "Bash(touch .claude/cache/mihomo-wiki/.last-pull:*)",
      "WebFetch(domain:docs.amnezia.org)",
      "WebFetch(domain:wiki.metacubex.one)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.sh) bash -n \"$f\" || exit 2;; esac",
            "statusMessage": "bash -n check"
          }
        ]
      }
    ]
  }
}
